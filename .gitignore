# ============================================================
# Etherpad — combined .gitignore for Android + iOS monorepo
# ============================================================

# ─── OS / editor ────────────────────────────────────────────
.DS_Store
*.swp
*~
Thumbs.db

# ─── Claude Code internal state ─────────────────────────────
.claude/

# ─── Old Eclipse era leftovers ──────────────────────────────
release-key.keystore
sign.sh

# ─── Local reference material — decompiled original APK ─────
# Kept on disk for diffing but never built or shipped.
legacy/

# ============================================================
# Android (Etherpad-Android/)
# ============================================================

# Build outputs
*.apk
*.aab
*.ap_
*.dex
build/
.gradle/
local.properties

# Android Studio / IntelliJ
.idea/
*.iml
captures/
.externalNativeBuild/
.cxx/

# ============================================================
# iOS + macOS (Etherpad-Apple/)
# ============================================================

# Xcode user-specific state (window layout, breakpoints, scheme
# selection, etc.) — never share between developers.
xcuserdata/
*.xcuserstate
*.xcuserdatad/
*.mode1v3
*.mode2v3
*.perspectivev3
*.pbxuser

# Xcode build / derived data
DerivedData/
build/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.swiftpm/
.build/
Package.resolved

# CocoaPods (if anyone adds it later)
Pods/

# Carthage
Carthage/Build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Csound xcframeworks and patched Obj-C shims (CsoundObj, CsoundMIDI) are tracked.
/android-demo
/docs/superpowers
