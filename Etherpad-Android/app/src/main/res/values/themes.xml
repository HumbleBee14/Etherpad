<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Minimal Compose-friendly theme. The actual look-and-feel is defined
         in Kotlin via Material 3's MaterialTheme. This base just ensures the
         system UI doesn't render anything before Compose takes over. -->
    <style name="Theme.Etherpad" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>
</resources>
